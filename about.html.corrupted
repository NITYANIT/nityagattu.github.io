    <meta charset="UTF-8">
       </div>

    <div id="achievements">
        <h2>Recent Achievements</h2>
        <div class="achievements-grid">
            <div class="achievement-card">
                <div class="achievement-icon">🏆</div>
                <div class="achievement-title">Google Girl Hackathon 2025</div>
                <div class="achievement-status">Semi-Finalist</div>
                <div class="achievement-desc">Selected as a semi-finalist in Google's prestigious Girl Hackathon 2025, competing among thousands of participants globally.</div>
            </div>
            <div class="achievement-card">
                <div class="achievement-icon">💼</div>
                <div class="achievement-title">JP Morgan Chase Code for Good 2025</div>
                <div class="achievement-status">Semi-Finalist</div>
                <div class="achievement-desc">Advanced to semi-finals in JP Morgan Chase's Code for Good hackathon, focusing on technology solutions for social impact.</div>
            </div>
            <div class="achievement-card">
                <div class="achievement-icon">⭐</div>
                <div class="achievement-title">HackerRank 4-Star Rating</div>
                <div class="achievement-status">SQL • Python • Java • C</div>
                <div class="achievement-desc">Achieved 4-star proficiency rating across multiple programming languages and technologies on HackerRank platform.</div>
            </div>
        </div>
    </div>

    <div id="certificates">`eta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Soha Farhana's Portfolio - About</title>
